<!DOCTYPE html>
<html lang="tr" class="h-full">
  <head>
    <title>PhishSim · Admin</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "brand_identity", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="h-full brand-bg-ice text-brand-midnight antialiased">
    <div class="flex min-h-screen">
      <!-- Sidebar -->
      <aside class="w-64 bg-[#00022d] border-r border-brand-azure/30 flex flex-col shadow-2xl relative z-20">
        <div class="px-6 py-8 border-b border-brand-azure/10 bg-brand-midnight/40">
          <h1 class="text-xl font-black tracking-tighter text-brand-ice uppercase italic">PhishSim</h1>
          <p class="text-[9px] text-brand-ice/60 font-black uppercase tracking-[0.2em] mt-1">Cyber Command Unit</p>
        </div>
        
        <nav class="flex-1 px-4 py-8 space-y-4">
          <% nav = [
               [ "Dashboard",          admin_dashboard_path,   "chart" ],
               [ "Campaign Builder",   admin_campaigns_path,   "send" ],
               [ "Analytics",          admin_analytics_path,   "bars" ],
               [ "Captured Creds",     admin_credentials_path, "lock" ]
             ] %>
          <% nav.each do |label, path, _| %>
            <% is_active = current_page?(path) %>
            <%= link_to path,
                  class: "group flex items-center px-4 py-3 rounded-xl transition-all duration-300 relative overflow-hidden border #{is_active ? 'bg-brand-azure/20 text-brand-ice shadow-lg shadow-brand-azure/20 border-brand-azure/60' : 'text-brand-ice/50 border-brand-azure/5 hover:text-brand-ice hover:border-brand-azure/30 hover:bg-brand-midnight/40'}" do %>
              <% if is_active %>
                <div class="absolute left-0 top-2 bottom-2 w-1 bg-brand-ice rounded-r-full shadow-[0_0_15px] shadow-brand-ice"></div>
              <% end %>
              <span class="text-[10px] font-black uppercase tracking-[0.2em] relative z-10"><%= label %></span>
            <% end %>
          <% end %>
        </nav>

      </aside>

      <!-- Main -->
      <main class="flex-1 p-8 overflow-y-auto">
        <% if flash[:notice] %>
          <div class="mb-4 px-4 py-3 rounded-md bg-brand-navy border border-brand-azure/40 text-brand-ice text-sm">
            <%= flash[:notice] %>
          </div>
        <% end %>
        <%= yield %>
      </main>
    </div>
  </body>
</html>
