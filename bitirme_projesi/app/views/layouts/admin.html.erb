<!DOCTYPE html>
<html lang="tr" class="h-full">
  <head>
    <title>PhishSim · Admin</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="h-full bg-slate-950 text-slate-100 antialiased">
    <div class="flex min-h-screen">
      <!-- Sidebar -->
      <aside class="w-60 bg-slate-900 border-r border-slate-800 flex flex-col">
        <div class="px-5 py-6 border-b border-slate-800">
          <h1 class="text-lg font-semibold tracking-tight">PhishSim</h1>
          <p class="text-xs text-slate-500 mt-1">Kadir Has University</p>
        </div>
        <nav class="flex-1 px-3 py-4 space-y-1 text-sm">
          <% nav = [
               [ "Dashboard",          admin_dashboard_path,   "chart" ],
               [ "Campaign Builder",   admin_campaigns_path,   "send" ],
               [ "Analytics",          admin_analytics_path,   "bars" ],
               [ "Captured Creds",     admin_credentials_path, "lock" ]
             ] %>
          <% nav.each do |label, path, _| %>
            <%= link_to label, path,
                  class: "block px-3 py-2 rounded-md hover:bg-slate-800 #{'bg-slate-800 text-white' if current_page?(path)}" %>
          <% end %>
        </nav>
        <div class="px-5 py-4 border-t border-slate-800 text-xs text-slate-500">
          bitirme projesi · v0.1
        </div>
      </aside>

      <!-- Main -->
      <main class="flex-1 p-8">
        <% if flash[:notice] %>
          <div class="mb-4 px-4 py-3 rounded-md bg-emerald-500/10 border border-emerald-500/30 text-emerald-300 text-sm">
            <%= flash[:notice] %>
          </div>
        <% end %>
        <%= yield %>
      </main>
    </div>
  </body>
</html>
