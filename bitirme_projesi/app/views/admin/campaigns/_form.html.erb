<%= form_with model: [:admin, campaign], class: "space-y-6" do |f| %>
  <% if campaign.errors.any? %>
    <div class="px-4 py-3 rounded-md bg-rose-500/10 border border-rose-500/30 text-rose-300 text-sm">
      <%= pluralize(campaign.errors.count, "hata") %> var:
      <ul class="list-disc pl-5 mt-2">
        <% campaign.errors.full_messages.each do |m| %><li><%= m %></li><% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Campaign Settings -->
    <div class="rounded-xl bg-slate-900 border border-slate-800 p-6">
      <h2 class="text-lg font-semibold mb-5">Campaign Settings</h2>
      <div class="space-y-4">
        <div>
          <%= f.label :name, class: "text-xs uppercase text-slate-400" %>
          <%= f.text_field :name, class: "mt-1 w-full bg-slate-800 border border-slate-700 rounded-md px-3 py-2 text-sm" %>
        </div>
        <div>
          <%= f.label :target_group, "Target Group", class: "text-xs uppercase text-slate-400" %>
          <%= f.select :target_group,
                [["All Students - Undergraduate", "all"], ["All Students - Graduate", "graduate"], ["Staff", "staff"]],
                {}, class: "mt-1 w-full bg-slate-800 border border-slate-700 rounded-md px-3 py-2 text-sm" %>
        </div>
        <div>
          <%= f.label :sender_email, "Sender", class: "text-xs uppercase text-slate-400" %>
          <%= f.text_field :sender_email, class: "mt-1 w-full bg-slate-800 border border-slate-700 rounded-md px-3 py-2 text-sm" %>
        </div>
        <div>
          <%= f.label :prompt_type, "Campaign Prompt", class: "text-xs uppercase text-slate-400" %>
          <%= f.select :prompt_type,
                [["Urgency-based", "urgency"], ["Authority-based", "authority"], ["Curiosity-based", "curiosity"]],
                {}, class: "mt-1 w-full bg-slate-800 border border-slate-700 rounded-md px-3 py-2 text-sm" %>
        </div>
      </div>
    </div>

    <!-- Scenario + Preview -->
    <div class="space-y-6">
      <div class="rounded-xl bg-slate-900 border border-slate-800 p-6">
        <h2 class="text-lg font-semibold mb-3">Scenario Definition</h2>
        <%= f.label :scenario_prompt, "AI Scenario Prompt", class: "text-xs uppercase text-slate-400" %>
        <%= f.text_area :scenario_prompt, rows: 4,
              class: "mt-1 w-full bg-slate-800 border border-slate-700 rounded-md px-3 py-2 text-sm" %>
      </div>

      <div class="rounded-xl bg-slate-800/40 border border-slate-800 p-6">
        <h2 class="text-lg font-semibold mb-4">AI Generated Email Preview</h2>
        <div class="text-xs space-y-1 text-slate-400 mb-4">
          <p><span class="text-slate-200 font-medium">From:</span> Kadir Has University IT &lt;<%= campaign.sender_email %>&gt;</p>
          <p><span class="text-slate-200 font-medium">To:</span> Student &lt;student@khas.edu.tr&gt;</p>
          <p><span class="text-slate-200 font-medium">Subject:</span> <%= campaign.email_subject.presence || "Waitlist Verification - Action Required" %></p>
        </div>
        <div class="text-sm leading-relaxed space-y-3 text-slate-200">
          <p>Dear Student,</p>
          <p>Your course registration for [Course Name] is on hold due to a data discrepancy. You must immediately verify your details on the secure student portal. Failure to complete this by 5:00 PM today will result in your removal from the waitlist...</p>
        </div>
        <div class="flex items-center gap-3 mt-4">
          <span class="inline-block text-xs bg-indigo-600 text-white px-3 py-1.5 rounded">Update Details</span>
          <span class="text-xs text-slate-500">http://localhost:3000/auth</span>
        </div>
      </div>
    </div>
  </div>

  <div class="flex justify-end gap-3">
    <%= link_to "İptal", admin_campaigns_path, class: "text-sm px-4 py-2 rounded-md border border-slate-700 text-slate-300" %>
    <%= f.submit "Kaydet", class: "text-sm px-4 py-2 rounded-md bg-indigo-600 hover:bg-indigo-500 text-white cursor-pointer" %>
  </div>
<% end %>
