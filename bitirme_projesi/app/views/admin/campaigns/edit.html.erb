<%= turbo_stream_from @campaign %>

<!-- AI Processing Modal -->
<div id="ai_generation_modal" 
     class="fixed inset-0 z-[100] bg-brand-midnight/60 backdrop-blur-md transition-all duration-500"
     style="display: <%= @campaign.ai_status == 'processing' ? 'flex' : 'none' %>; align-items: center; justify-content: center;">
  <div class="bg-white border border-brand-azure/20 rounded-3xl shadow-2xl p-8 relative" style="width: 450px; max-width: 90vw;">
    <!-- Manual Close -->
    <button type="button" onclick="document.getElementById('ai_generation_modal').style.display='none';" class="absolute top-4 right-4 text-brand-sky/40 hover:text-brand-ice transition-colors cursor-pointer p-2 z-[110]">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <% if @campaign.ai_status == 'processing' %>
      <% 
         total = @campaign.ai_total_count.to_f
         total = 1.0 if total <= 0
         pct = ((@campaign.ai_processed_count.to_f / total) * 100).round 
      %>
      <%= render "ai_progress", campaign: @campaign, percentage: pct, current_email: "Resuming Synthesis...", is_live: false %>
    <% else %>
      <%= render "ai_progress", campaign: @campaign, percentage: 0, current_email: "Initializing...", is_live: false %>
    <% end %>
  </div>
</div>

<div class="flex items-center justify-between mb-6">
  <div class="flex flex-col text-left mr-auto">
    <h1 class="brand-header-primary !text-left">
      Edit Campaign
    </h1>
    <p class="text-[10px] text-brand-midnight/60 font-bold uppercase tracking-widest mt-1">Configure mission parameters and target data.</p>
  </div>
  
  <div class="flex gap-3">
    <!-- Delete Mission Action -->
    <%= link_to admin_campaign_path(@campaign), 
          data: { turbo_method: :delete, turbo_confirm: "TERMINATE MISSION? ALL INTELLIGENCE DATA WILL BE PURGED." },
          class: "btn-danger flex items-center justify-center gap-2 px-4 py-2 !rounded-xl transition-all hover:scale-105 active:scale-95 group" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white opacity-80 group-hover:opacity-100" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
      </svg>
      <span class="text-[9px] font-black uppercase tracking-widest text-white">Delete Campaign</span>
    <% end %>

    <!-- Update Action Link -->
    <button type="submit" form="campaign-form" class="btn-command flex items-center gap-2 px-6 py-2 !rounded-xl transition-all hover:scale-105 active:scale-95">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
      </svg>
      <span class="text-[9px] font-black uppercase tracking-[0.2em]">Update Mission</span>
    </button>

    <%= link_to admin_campaigns_path, class: "btn-secondary !p-3 !rounded-xl" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
      </svg>
    <% end %>
  </div>
</div>

<!-- Campaign Config Form -->
<%= render "form", campaign: @campaign %>

<!-- Target Management Section -->
<div class="mt-12 pt-8 border-t border-brand-azure/10">
  <div class="flex items-center justify-between mb-4">
    <div>
      <h2 class="text-lg font-black uppercase tracking-tight text-brand-midnight italic">Target List & Personalization</h2>
      <p class="text-[10px] text-brand-midnight/60 font-bold uppercase tracking-widest mt-1">Manage intelligence profiles and AI content.</p>
    </div>
    
    <div class="flex gap-3">
      <%= button_to "GENERATE AI EMAILS", generate_ai_content_admin_campaign_path(@campaign),
            method: :post, 
            onclick: "document.getElementById('ai_generation_modal').style.display='flex';",
            class: "btn-secondary text-[10px]" %>
      
      <%= form_with url: send_now_admin_campaign_path(@campaign), method: :post, class: "flex items-center gap-2 bg-white p-1.5 rounded-xl border border-brand-azure/10" do |f| %>
        <%= f.datetime_local_field :scheduled_time, class: "bg-white border border-brand-azure/10 text-brand-midnight text-xs rounded-lg p-2 focus:ring-brand-azure outline-none", placeholder: "Schedule..." %>
        <%= f.submit "LAUNCH", class: "btn-command text-[10px] !px-4 !py-2" %>
      <% end %>
    </div>
  </div>


  <div class="brand-card-solid overflow-hidden">
    <div class="p-6 border-b border-brand-azure/5 bg-brand-azure/[0.02] flex items-center justify-between">
      <h2 class="text-xs font-black uppercase tracking-widest text-brand-midnight/30">Target Database</h2>
      <span class="text-[10px] py-1 px-3 rounded-full bg-brand-ice/40 text-brand-midnight/60 font-bold border border-brand-azure/10">
        <%= @campaign.campaign_targets.count %> Targets Loaded
      </span>
    </div>

    <table class="w-full text-left text-sm border-collapse">
      <thead class="bg-brand-azure/5 text-brand-midnight/40 text-[10px] uppercase font-black tracking-[0.2em]">
        <tr>
          <th class="px-6 py-3">Name / Identity</th>
          <th class="px-6 py-3">Organizational Unit</th>
          <th class="px-6 py-3 text-center">Spam Analysis</th>
          <th class="px-6 py-3">AI Meta-Data State</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-brand-navy/50">
        <% if @campaign.campaign_targets.any? %>
          <% @campaign.campaign_targets.each do |ct| %>
            <!-- User Row -->
            <tr class="hover:bg-brand-azure/5 transition-colors group">
              <td class="px-6 py-3">
                <div class="flex items-center gap-3">
                  <% if ct.personalized_body.present? %>
                    <button type="button" 
                            onclick="const row = document.getElementById('preview-row-<%= ct.id %>'); row.style.display = (row.style.display === 'none' ? 'table-row' : 'none');"
                            class="w-8 h-8 rounded-lg bg-brand-midnight text-white flex items-center justify-center hover:bg-brand-azure transition-all cursor-pointer">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                      </svg>
                    </button>
                  <% else %>
                    <div class="w-8 h-8 rounded-lg bg-brand-ice/20 text-brand-midnight/40 flex items-center justify-center border border-brand-azure/10">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.956 9.956 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />
                      </svg>
                    </div>
                  <% end %>
                  <div>
                    <div class="font-black text-brand-midnight text-xs tracking-tight"><%= ct.target.full_name %></div>
                    <div class="text-[10px] text-brand-midnight/40 font-bold uppercase tracking-wider group-hover:text-brand-azure transition-colors"><%= ct.target.email %></div>
                  </div>
                </div>
              </td>
              <td class="px-6 py-3">
                <div class="text-[11px] text-brand-midnight font-bold"><%= ct.custom_data['department'] %></div>
                <div class="text-[9px] text-brand-midnight/40 font-black uppercase tracking-widest"><%= ct.custom_data['role'] %></div>
              </td>
              <td class="px-6 py-3 text-center">
                <% if ct.spam_score.nil? %>
                  <span class="text-[9px] text-brand-midnight/20 italic">N/A</span>
                <% else %>
                  <% badge_color = ct.spam_score.to_i < 5 ? "bg-brand-ice/20 text-brand-midnight/40 border-brand-azure/10" : "bg-brand-alert/10 text-brand-alert border-brand-alert/40" %>
                  <div class="inline-flex items-center">
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold border <%= badge_color %>">
                      <%= ct.spam_score %>
                    </span>
                  </div>
                <% end %>
              </td>
              <td class="px-6 py-3">
                <% if ct.personalized_body.present? %>
                  <span class="inline-flex items-center gap-1 py-0.5 px-2 rounded-full bg-brand-azure/10 text-brand-azure text-[9px] font-black uppercase tracking-widest border border-brand-azure/30">
                    <span class="w-1 h-1 rounded-full bg-brand-azure"></span>
                    Ready
                  </span>
                <% else %>
                  <span class="inline-flex items-center gap-1 py-0.5 px-2 rounded-full bg-brand-ice/20 text-brand-midnight/20 text-[9px] font-black uppercase tracking-widest border border-brand-azure/10">
                    <span class="w-1 h-1 rounded-full bg-brand-midnight/20 animate-pulse"></span>
                    Wait
                  </span>
                <% end %>
              </td>
            </tr>

            <!-- Inline Preview Row -->
            <% if ct.personalized_body.present? %>
              <tr id="preview-row-<%= ct.id %>" style="display: none;" class="bg-brand-azure/5">
                <td colspan="4" class="px-8 py-8">
                  <div class="rounded-xl border border-brand-azure/20 bg-white overflow-hidden shadow-2xl max-w-6xl mx-auto font-sans text-brand-midnight flex flex-col h-[600px]">
                    
                    <!-- Outlook Top Nav (Now Azure) -->
                    <div class="h-12 bg-brand-azure flex justify-between items-center px-4 shrink-0">
                      <div class="flex items-center gap-4">
                        <svg class="text-brand-midnight w-5 h-5 cursor-pointer hover:opacity-80" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 10a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 15a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z" clip-rule="evenodd"></path></svg>
                        <span class="text-brand-midnight font-semibold text-sm">Microsoft 365</span>
                        <span class="text-brand-midnight/80 font-semibold text-sm border-l border-brand-midnight/20 pl-4 ml-2">Outlook</span>
                      </div>
                      <div class="w-96 bg-brand-midnight/10 h-8 rounded text-brand-midnight/60 flex items-center px-3 text-xs">
                        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                        Search
                      </div>
                      <div class="flex items-center gap-4">
                        <svg class="text-brand-midnight w-5 h-5 cursor-pointer" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                        <div class="w-8 h-8 rounded-full bg-brand-navy text-brand-ice flex items-center justify-center text-xs font-bold border border-brand-ice/20">
                          <%= ct.target.full_name.split(' ').map(&:first).join('').upcase.first(2) %>
                        </div>
                        <button type="button" onclick="document.getElementById('preview-row-<%= ct.id %>').style.display='none';" class="ml-2 px-3 py-1 bg-brand-ice text-brand-navy hover:bg-brand-midnight hover:text-brand-ice rounded text-xs font-bold transition-colors">Close</button>
                      </div>
                    </div>

                    <div class="flex flex-1 overflow-hidden">
                      <!-- Outlook Sidebar (Light Mode) -->
                      <div class="w-56 bg-brand-ice/20 border-r border-brand-azure/10 p-2 hidden md:block shrink-0 overflow-y-auto">
                        <div class="flex flex-col gap-0.5 mt-2">
                          <button class="flex items-center gap-3 px-3 py-2 text-sm font-semibold bg-brand-ice/10 text-brand-ice rounded">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path></svg>
                            Inbox
                          </button>
                          <button class="flex items-center gap-3 px-3 py-2 text-sm text-brand-sky/60 hover:bg-brand-navy rounded">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path></svg>
                            Sent
                          </button>
                          <button class="flex items-center gap-3 px-3 py-2 text-sm text-brand-sky/60 hover:bg-brand-navy rounded">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                            Drafts
                          </button>
                        </div>
                      </div>

                      <!-- Preview Content -->
                      <div class="flex-1 overflow-y-auto bg-white flex flex-col">
                        <div class="h-10 border-b border-brand-azure/5 flex items-center px-4 gap-6 shrink-0 bg-white/50">
                          <button class="text-sm font-semibold text-brand-sky/60 flex items-center gap-2 hover:text-brand-ice uppercase tracking-tighter"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"></path></svg> Reply</button>
                          <button class="text-sm font-semibold text-brand-sky/60 flex items-center gap-2 hover:text-brand-ice uppercase tracking-tighter"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.933 12.8a1 1 0 000-1.6L6.6 7.2A1 1 0 005 8v8a1 1 0 001.6.8l5.333-4zM19.933 12.8a1 1 0 000-1.6l-5.333-4A1 1 0 0013 8v8a1 1 0 001.6.8l5.333-4z"></path></svg> Forward</button>
                          <div class="border-l border-brand-navy h-5"></div>
                          <button class="text-sm font-semibold text-brand-azure flex items-center gap-2 relative">
                            <span class="w-2 h-2 rounded-full bg-brand-ice absolute -top-1 -right-2 animate-ping"></span>
                            <svg class="w-4 h-4 text-brand-azure" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"></path></svg> Report Phishing
                          </button>
                        </div>

                        <!-- Email Content -->
                        <div class="flex-1 p-8">
                          <h2 class="text-2xl font-black mb-6 text-brand-midnight italic tracking-tight"><%= ct.personalized_subject %></h2>
                          
                          <!-- Sender Header -->
                          <div class="flex items-start gap-4 mb-8">
                            <div class="w-10 h-10 rounded-full bg-brand-azure text-brand-midnight flex items-center justify-center font-bold font-sans">
                              K
                            </div>
                            <div class="flex flex-col">
                              <div class="flex items-center gap-2">
                                <span class="font-black text-brand-midnight text-sm uppercase tracking-tight">Kadir Has University</span>
                                <span class="text-[10px] text-brand-midnight/40 font-mono italic"><<%= @campaign.sender_email %>></span>
                              </div>
                              <div class="text-[10px] text-brand-midnight/40 mt-0.5 uppercase tracking-widest font-bold">
                                To: <span class="text-brand-midnight/60"><%= ct.target.full_name %></span>
                                <span class="mx-2 text-brand-azure/20">•</span>
                                <span class="text-brand-midnight/40 font-mono italic"><%= Time.current.strftime("%d %B %Y %H:%M") %></span>
                              </div>
                            </div>
                          </div>

                          <div class="text-sm text-brand-midnight/60 leading-relaxed max-w-3xl font-sans mt-4">
                            <% 
                               # Link Injection
                               phishing_link = auth_with_token_url(token: ct.target.token, host: "localhost", port: 3000)
                               # Replace raw links with brand azure outlook links
                               body_html = ct.personalized_body.gsub(phishing_link, "<a href='#{phishing_link}' target='_blank' class='text-brand-azure hover:underline font-semibold' style='text-decoration-color: var(--brand-azure);'>#{phishing_link}</a>").html_safe
                            %>
                            <%= simple_format(body_html) %>
                          </div>
                          
                          <!-- Corporate Footer Mockup -->
                          <div class="mt-12 pt-8 border-t border-brand-navy">
                            <p class="text-[10px] text-brand-sky/40 font-bold uppercase tracking-widest leading-loose">
                              <span class="text-brand-azure">Kadir Has University</span><br/>
                              Cyber Infrastructure Research Lab<br/>
                              <em class="italic opacity-60">This simulation is system generated for education.</em>
                            </p>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </td>
              </tr>
            <% end %>
          <% end %>
        <% else %>
          <tr>
            <td colspan="4" class="px-8 py-20 text-center">
              <div class="text-center py-20 px-4 bg-brand-azure/5 rounded-3xl border border-dashed border-brand-azure/10">
                <div class="w-12 h-12 rounded-full bg-brand-midnight flex items-center justify-center mx-auto text-white">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                </div>
                <h3 class="text-sm font-black text-brand-midnight/40 uppercase tracking-widest mt-4">Database Empty</h3>
                <p class="text-[10px] text-brand-midnight/20 leading-relaxed italic uppercase mt-1">Upload strategy file to hydrate targeting matrix.</p>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
