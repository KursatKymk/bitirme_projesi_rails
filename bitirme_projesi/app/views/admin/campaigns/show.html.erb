<div class="flex items-center justify-between mb-8">
  <div class="flex flex-col">
    <div class="flex items-center gap-3">
        <h1 class="text-3xl font-black tracking-tight text-brand-ice uppercase"><%= @campaign.name %></h1>
          <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-tighter
            <%= @campaign.status == 'sent' ? 'bg-brand-navy text-brand-ice border border-brand-ice/20' : 'bg-brand-navy text-brand-sky/40 border border-brand-azure/10' %>">
            <%= @campaign.status %>
          </span>
    </div>
    <p class="text-xs text-brand-sky/40 mt-2 flex items-center gap-2">
      <span class="uppercase tracking-widest font-bold text-brand-sky/60"><%= @campaign.email_language %></span>
      <span class="opacity-20">•</span>
      <span class="uppercase tracking-widest font-bold text-brand-sky/60"><%= @campaign.prompt_type %></span>
      <span class="opacity-20">•</span>
      <span>Simulated via <%= @campaign.sender_email %></span>
    </p>
  </div>
  
  <div class="flex gap-3">
    <%= link_to "Edit Campaign", edit_admin_campaign_path(@campaign), class: "text-[10px] font-black tracking-widest px-6 py-3 rounded-xl border border-brand-navy/80 text-brand-sky/60 hover:text-brand-ice hover:bg-brand-navy transition-all uppercase" %>
    
    <% if @campaign.status == 'draft' %>
        <%= button_to send_now_admin_campaign_path(@campaign),
              method: :post, 
              class: "text-[10px] font-black tracking-widest px-8 py-3 rounded-xl bg-brand-azure hover:bg-brand-azure/80 text-brand-midnight transition-all shadow-lg shadow-brand-azure/20 uppercase cursor-pointer" do %>
            Start Simulation
        <% end %>
    <% end %>
  </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
  <%= render "admin/dashboard/kpi", title: "Emails Sent",     value: @campaign.emails_sent %>
  <%= render "admin/dashboard/kpi", title: "Unique Opens",   value: @campaign.emails_opened %>
  <%= render "admin/dashboard/kpi", title: "Total Clicks",   value: @campaign.links_clicked %>
  <%= render "admin/dashboard/kpi", title: "Data Captured", value: @campaign.creds_captured, alert: true %>
</div>

<div class="grid grid-cols-1 gap-6 mb-8">
    <!-- Active Scenario Box (On Top) -->
    <div class="rounded-2xl bg-brand-midnight border border-brand-navy p-8 shadow-xl">
        <h2 class="text-xs font-bold uppercase tracking-widest text-brand-sky/40 mb-6 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" /></svg>
            Active Simulation Scenario
        </h2>
        <div class="relative">
            <div class="absolute -left-4 top-0 bottom-0 w-1 bg-brand-azure/30 rounded-full"></div>
            <p class="text-sm text-brand-sky leading-relaxed font-serif italic selection:bg-brand-azure/30">
                <% if @campaign.use_custom_scenario %>
                    <%= @campaign.scenario_prompt %>
                <% else %>
                    <span class="text-brand-ice font-black uppercase tracking-tighter text-[10px] block mb-2 shadow-brand-ice/20">Autonomous AI Mode</span>
                    The AI independently generates unique administrative topics (IT, Finance, HR, Library) for every recipient in this campaign to maximize diversity and realistic engagement.
                <% end %>
            </p>
        </div>
    </div>

    <!-- Target Database Table (Below) -->
    <div class="rounded-2xl bg-brand-midnight border border-brand-navy overflow-hidden shadow-xl">
        <div class="p-6 border-b border-brand-navy bg-brand-navy/20 flex items-center justify-between">
            <h2 class="text-xs font-bold uppercase tracking-widest text-brand-sky/60">Campaign Target Database</h2>
            <span class="text-[10px] px-3 py-1 rounded-full bg-brand-navy text-brand-sky/40 font-bold border border-brand-azure/10">
                <%= @campaign.campaign_targets.count %> Recipients
            </span>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm">
                <thead class="bg-brand-navy/40 text-brand-sky/40 text-[10px] uppercase font-black tracking-[0.2em]">
                    <tr>
                        <th class="px-6 py-4">Target Identity</th>
                        <th class="px-6 py-4">Department / Role</th>
                        <th class="px-6 py-4">Simulation State</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-brand-navy/50">
                    <% @campaign.campaign_targets.each do |ct| %>
                        <tr class="hover:bg-brand-navy/10 transition-colors">
                            <td class="px-6 py-4">
                                <div class="font-bold text-brand-ice"><%= ct.target.full_name %></div>
                                <div class="text-[10px] text-brand-sky/50"><%= ct.target.email %></div>
                            </td>
                            <td class="px-6 py-4">
                                <div class="text-xs text-brand-sky/80 font-medium"><%= ct.custom_data['departman'] %></div>
                                <div class="text-[9px] text-brand-sky/40 uppercase tracking-widest font-bold"><%= ct.custom_data['rol'] %></div>
                            </td>
                            <td class="px-6 py-4">
                                <% events = @campaign.email_events.where(target: ct.target).pluck(:event_type) %>
                                <div class="flex gap-2">
                                    <div class="flex flex-col items-center gap-1">
                                        <span class="w-2 h-2 rounded-full <%= events.include?('sent') ? 'bg-brand-azure shadow-[0_0_8px] shadow-brand-azure/50' : 'bg-brand-navy/60' %>"></span>
                                        <span class="text-[8px] font-bold text-brand-sky/40 uppercase">Sent</span>
                                    </div>
                                    <div class="flex items-center gap-1.5" title="Opened">
                                        <span class="w-2 h-2 rounded-full <%= events.include?('opened') ? 'bg-brand-ice shadow-[0_0_8px] shadow-brand-ice/60' : 'bg-brand-navy/60' %>"></span>
                                        <span class="text-[9px] font-black <%= events.include?('opened') ? 'text-brand-ice' : 'text-brand-sky/20' %> uppercase">View</span>
                                    </div>
                                    <div class="flex items-center gap-1.5" title="Clicked">
                                        <span class="w-2 h-2 rounded-full <%= events.include?('clicked') ? 'bg-brand-azure shadow-[0_0_8px] shadow-brand-azure/60' : 'bg-brand-navy/60' %>"></span>
                                        <span class="text-[9px] font-black <%= events.include?('clicked') ? 'text-brand-azure' : 'text-brand-sky/20' %> uppercase">Click</span>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    <% end %>
                </tbody>
            </table>
        </div>
    </div>
</div>
