<div class="flex items-center justify-between mb-6">
  <h1 class="brand-header-primary">Captured Credentials</h1>
  <span class="text-xs text-brand-azure/60 font-bold uppercase tracking-widest"><%= @credentials.size %> records</span>
</div>

<div class="brand-card-solid overflow-hidden">
  <table class="w-full text-sm text-left">
    <thead class="bg-brand-azure/5 text-brand-midnight/40 text-[10px] uppercase font-black tracking-[0.22em]">
      <tr>
        <th class="px-8 py-5">Captured At</th>
        <th class="px-8 py-5">Campaign</th>
        <th class="px-8 py-5">Email Identity</th>
        <th class="px-8 py-5">Masked Value</th>
        <th class="px-8 py-5">Telemetry IP</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-brand-azure/10">
      <% @credentials.each do |c| %>
        <tr class="hover:bg-brand-azure/5 transition-colors group">
          <td class="px-8 py-5 text-brand-midnight/40 font-mono text-[10px] italic"><%= c.captured_at&.strftime("%d.%m %H:%M") %></td>
          <td class="px-8 py-5 text-brand-midnight font-bold"><%= c.campaign&.name %></td>
          <td class="px-8 py-5 text-brand-midnight/60"><%= c.email %></td>
          <td class="px-8 py-5">
            <span class="font-mono text-brand-midnight font-black tracking-wider">
              <%= c.masked_password %>
            </span>
          </td>
          <td class="px-8 py-5 text-brand-midnight/20 font-mono text-[10px]"><%= c.ip_address %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
