<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold tracking-tight">CAPTURED CREDENTIALS</h1>
  <span class="text-xs text-slate-500"><%= @credentials.size %> kayıt</span>
</div>

<div class="rounded-xl bg-slate-900 border border-slate-800 overflow-hidden">
  <table class="w-full text-sm">
    <thead class="text-slate-400 text-xs uppercase">
      <tr>
        <th class="px-5 py-3 text-left">Captured At</th>
        <th class="px-5 py-3 text-left">Campaign</th>
        <th class="px-5 py-3 text-left">Email</th>
        <th class="px-5 py-3 text-left">Password</th>
        <th class="px-5 py-3 text-left">IP</th>
      </tr>
    </thead>
    <tbody>
      <% @credentials.each do |c| %>
        <tr class="border-t border-slate-800">
          <td class="px-5 py-3 text-slate-400"><%= c.captured_at&.strftime("%d.%m %H:%M") %></td>
          <td class="px-5 py-3"><%= c.campaign&.name %></td>
          <td class="px-5 py-3"><%= c.email %></td>
          <td class="px-5 py-3 font-mono text-rose-300"><%= c.masked_password %></td>
          <td class="px-5 py-3 text-slate-500"><%= c.ip_address %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
