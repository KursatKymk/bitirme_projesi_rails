<div class="flex items-center justify-between mb-5">
  <div class="flex flex-col">
    <h1 class="brand-header-primary">Vulnerability Intelligence</h1>
    <p class="text-[10px] text-brand-midnight/60 font-bold uppercase tracking-widest mt-1">Advanced psychological and temporal risk analysis suite.</p>
  </div>
</div>

<!-- KPI SECTION -->
<div class="grid grid-cols-1 md:grid-cols-4 gap-3 mb-6">
  <%= render "admin/dashboard/kpi", title: "Global Reach",     value: number_with_delimiter(@total_sent) %>
  <%= render "admin/dashboard/kpi", title: "Open Rate",       value: "#{@total_sent > 0 ? (@total_opened.to_f / @total_sent * 100).round(1) : 0}%" %>
  <%= render "admin/dashboard/kpi", title: "Click-Through",   value: "#{@total_sent > 0 ? (@total_clicked.to_f / @total_sent * 100).round(1) : 0}%" %>
  <div class="rounded-3xl bg-white border border-brand-alert/10 p-5 shadow-2xl shadow-brand-midnight/5 relative overflow-hidden group">
    <div class="absolute top-0 right-0 w-32 h-32 bg-brand-alert/5 rounded-full blur-3xl -mr-16 -mt-16 group-hover:bg-brand-alert/10 transition-all duration-700"></div>
    <div class="text-[10px] font-black uppercase tracking-[0.2em] text-brand-alert mb-1">Breach Velocity</div>
    <div class="text-3xl font-black tracking-tighter text-brand-midnight leading-none"><%= number_with_delimiter(@total_creds) %></div>
    <div class="mt-2 text-[9px] text-brand-alert/40 font-bold uppercase tracking-widest italic">Critical compromise count</div>
  </div>
</div>

<!-- MAIN INTELLIGENCE GRID -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6">
  
  <!-- Trigger Effectiveness (Psychological Analysis) -->
  <div class="brand-card-solid p-5 relative group min-h-0">
    <h2 class="text-lg font-black uppercase tracking-tight text-brand-midnight italic mb-4">Trigger Analysis (Psych)</h2>
    <div class="h-48 relative flex items-center justify-center">
      <canvas id="triggerChart"></canvas>
      <div id="triggerEmpty" class="hidden absolute inset-0 flex items-center justify-center pointer-events-none text-[9px] text-brand-midnight/20 font-black uppercase tracking-widest italic text-center">Insufficient Simulation Data</div>
    </div>
  </div>

  <!-- Hourly Risk Heatmap (Temporal Analysis) -->
  <div class="brand-card-solid p-5 relative group min-h-0">
    <h2 class="text-lg font-black uppercase tracking-tight text-brand-midnight italic mb-4">Peak Risk (Hourly)</h2>
    <div class="h-48 relative flex items-center justify-center">
      <canvas id="hourlyChart"></canvas>
      <div id="hourlyEmpty" class="hidden absolute inset-0 flex items-center justify-center pointer-events-none text-[9px] text-brand-midnight/20 font-black uppercase tracking-widest italic text-center">Awaiting Interaction Peaks</div>
    </div>
  </div>


</div>

<!-- FORENSIC INTELLIGENCE GRID -->
<div class="grid grid-cols-1 lg:grid-cols-12 gap-4 mb-6">
  
  <!-- Breach Timeline Chart -->
  <div class="lg:col-span-8 brand-card-solid p-5 group relative">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-black uppercase tracking-tight text-brand-midnight italic">Forensic Incident Timeline (30 Days)</h2>
      <span class="text-[9px] font-black text-brand-alert uppercase tracking-widest animate-pulse">Live Threat Feed</span>
    </div>
    <div class="h-60 relative flex items-center justify-center">
      <canvas id="timelineChart"></canvas>
      <div id="timelineEmpty" class="hidden absolute inset-0 flex items-center justify-center pointer-events-none text-[10px] text-brand-midnight/20 font-black uppercase tracking-widest italic">No Breach Activity Recorded</div>
    </div>
  </div>

  <!-- Language Effectiveness Chart -->
  <div class="lg:col-span-4 brand-card-solid p-5">
    <h2 class="text-lg font-black uppercase tracking-tight text-brand-midnight italic mb-4">Cultural Vulnerability</h2>
    <div class="h-48 relative flex items-center justify-center">
      <canvas id="languageChart"></canvas>
      <div id="languageEmpty" class="hidden absolute inset-0 flex items-center justify-center pointer-events-none text-[10px] text-brand-midnight/20 font-black uppercase tracking-widest italic">Pending Language Assets</div>
    </div>
    <div class="mt-6 space-y-4">
      <% @language_data.each do |lang, stats| %>
        <div class="flex items-center justify-between p-3 rounded-xl bg-white border border-brand-azure/10">
          <div class="flex items-center gap-3">
            <span class="text-[10px] font-black text-brand-midnight uppercase"><%= lang %></span>
          </div>
          <div class="flex items-center gap-4">
            <div class="text-right">
              <div class="text-[8px] text-brand-midnight/30 font-black uppercase">CTR</div>
              <div class="text-xs font-bold text-brand-azure"><%= stats[:ctr] %>%</div>
            </div>
            <div class="text-right">
              <div class="text-[8px] text-brand-midnight/30 font-black uppercase">BREACH</div>
              <div class="text-xs font-black text-brand-alert"><%= stats[:breach] %>%</div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>

</div>

<!-- HIGH RISK TARGETS -->
<div class="brand-card-solid p-5 backdrop-blur-none mb-6">
  <div class="flex items-center gap-4 mb-4">
    <div class="w-10 h-10 rounded-2xl bg-brand-alert/5 border border-brand-alert/20 flex items-center justify-center">
      <svg class="w-5 h-5 text-brand-alert" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
      </svg>
    </div>
    <div>
      <h2 class="text-lg font-black text-brand-midnight uppercase tracking-tight italic">High-Risk Exposure Vectors</h2>
      <p class="text-[10px] text-brand-alert/60 font-black uppercase tracking-widest">Identifying the top 5 simulated compromise points.</p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-5 gap-3">
    <% if @top_targets.empty? %>
      <div class="col-span-5 py-12 text-center text-[10px] text-brand-midnight/20 font-black uppercase tracking-widest italic">No high-risk vectors identified in current operations.</div>
    <% else %>
      <% @top_targets.each_with_index do |t, i| %>
        <div class="p-5 rounded-2xl bg-brand-ice/10 border border-brand-azure/10 hover:border-brand-alert/40 transition-all group">
          <div class="text-brand-alert/20 font-black text-2xl mb-2 italic">#0<%= i+1 %></div>
          <div class="text-xs font-black text-brand-midnight truncate mb-4" title="<%= t.email %>"><%= t.email %></div>
          <div class="flex items-center justify-between">
            <div>
              <div class="text-[8px] text-brand-midnight/30 font-black uppercase">Clicks</div>
              <div class="text-sm font-black text-brand-azure"><%= t.click_count %></div>
            </div>
            <div class="text-right">
              <div class="text-[8px] text-brand-midnight/30 font-black uppercase">Breaches</div>
              <div class="text-sm font-black text-brand-alert"><%= t.breach_count %></div>
            </div>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  (function() {
    function initCharts() {
      if(!window.Chart) return;
      const pal = <%= raw brand_palette.to_json %>;

      const cleanup = (id) => {
        const oldCtx = document.getElementById(id);
        if (oldCtx && oldCtx.dataset.initialized) {
          const chart = Chart.getChart(oldCtx);
          if (chart) chart.destroy();
        }
      };

      // 1. Trigger Effectiveness
      cleanup('triggerChart');
      const triggerData = <%= raw @strategy_data.to_json %>;
      const hasTriggerData = Object.values(triggerData).some(d => d.ctr > 0 || d.breach > 0);
      const triggerCtx = document.getElementById('triggerChart');
      if (triggerCtx) {
        if (!hasTriggerData) {
          document.getElementById('triggerEmpty')?.classList.remove('hidden');
          triggerCtx.classList.add('opacity-0');
        } else {
          document.getElementById('triggerEmpty')?.classList.add('hidden');
          triggerCtx.classList.remove('opacity-0');
          triggerCtx.dataset.initialized = 'true';
          new Chart(triggerCtx, {
            type: 'bar',
            data: {
              labels: Object.keys(triggerData).map(l => l.toUpperCase()),
              datasets: [
                { label: 'Click Rate (%)', data: Object.values(triggerData).map(d => d.ctr), backgroundColor: pal.azure, borderRadius: 6 },
                { label: 'Breach Rate (%)', data: Object.values(triggerData).map(d => d.breach), backgroundColor: pal.alert, borderRadius: 6 }
              ]
            },
            options: {
              responsive: true, maintainAspectRatio: false,
              plugins: { legend: { position: 'bottom', labels: { color: pal.midnight, font: { weight: 'bold', size: 9 }, padding: 20 } } },
              scales: {
                y: { grid: { color: 'rgba(0,3,61,0.05)' }, ticks: { color: pal.midnight, font: { size: 9 } } },
                x: { grid: { display: false }, ticks: { color: pal.midnight, font: { weight: 'bold', size: 9 } } }
              }
            }
          });
        }
      }

      // 2. Hourly Risk
      cleanup('hourlyChart');
      const hourlySeries = <%= raw @hourly_series %>;
      const hasHourlyData = hourlySeries.some(v => v > 0);
      const hourlyCtx = document.getElementById('hourlyChart');
      if (hourlyCtx) {
        if (!hasHourlyData) {
          document.getElementById('hourlyEmpty')?.classList.remove('hidden');
          hourlyCtx.classList.add('opacity-0');
        } else {
          document.getElementById('hourlyEmpty')?.classList.add('hidden');
          hourlyCtx.classList.remove('opacity-0');
          hourlyCtx.dataset.initialized = 'true';
          new Chart(hourlyCtx, {
            type: 'line',
            data: {
              labels: <%= raw (0..23).to_a.map{|h| "#{h}:00"} %>,
              datasets: [{
                label: 'Interaction Spike', data: hourlySeries, borderColor: pal.azure, backgroundColor: 'rgba(0, 51, 255, 0.2)',
                fill: true, tension: 0.4, borderWidth: 3, pointRadius: 2, pointBackgroundColor: pal.ice
              }]
            },
            options: {
              responsive: true, maintainAspectRatio: false,
              plugins: { legend: { display: false } },
              scales: {
                y: { beginAtZero: true, grid: { color: 'rgba(0,3,61,0.05)' }, ticks: { color: pal.midnight, font: { size: 9 } } },
                x: { grid: { display: false }, ticks: { color: pal.midnight, autoSkip: true, font: { size: 8 } } }
              }
            }
          });
        }
      }

      // 3. Language Effectiveness
      cleanup('languageChart');
      const langData = <%= raw @language_data.to_json %>;
      const hasLangData = Object.values(langData).some(d => d.ctr > 0 || d.breach > 0);
      const langCtx = document.getElementById('languageChart');
      if (langCtx) {
        if (!hasLangData) {
          document.getElementById('languageEmpty')?.classList.remove('hidden');
          langCtx.classList.add('opacity-0');
        } else {
          document.getElementById('languageEmpty')?.classList.add('hidden');
          langCtx.classList.remove('opacity-0');
          langCtx.dataset.initialized = 'true';
          new Chart(langCtx, {
            type: 'doughnut',
            data: {
              labels: Object.keys(langData).map(l => l.toUpperCase()),
              datasets: [{
                data: Object.values(langData).map(d => d.breach),
                backgroundColor: [pal.azure, pal.sky, pal.ice],
                borderWidth: 0,
                hoverOffset: 10
              }]
            },
            options: {
              responsive: true, maintainAspectRatio: false,
              cutout: '75%',
              plugins: { legend: { display: false } }
            }
          });
        }
      }

      // 4. Timeline Analysis
      cleanup('timelineChart');
      const timelineLabels = <%= raw @timeline_labels %>;
      const timelineSeries = <%= raw @timeline_series %>;
      const hasTimelineData = timelineSeries.some(v => v > 0);
      const timelineCtx = document.getElementById('timelineChart');
      if (timelineCtx) {
        if (!hasTimelineData) {
          document.getElementById('timelineEmpty')?.classList.remove('hidden');
          timelineCtx.classList.add('opacity-0');
        } else {
          document.getElementById('timelineEmpty')?.classList.add('hidden');
          timelineCtx.classList.remove('opacity-0');
          timelineCtx.dataset.initialized = 'true';
          new Chart(timelineCtx, {
            type: 'line',
            data: {
              labels: timelineLabels,
              datasets: [{
                label: 'Daily Breaches', data: timelineSeries, borderColor: pal.alert, 
                backgroundColor: 'rgba(255, 0, 85, 0.1)', fill: true, tension: 0.1, 
                borderWidth: 2, pointRadius: 4, pointBackgroundColor: pal.alert
              }]
            },
            options: {
              responsive: true, maintainAspectRatio: false,
              plugins: { legend: { display: false } },
              scales: {
                y: { beginAtZero: true, grid: { color: 'rgba(255, 0, 85, 0.05)' }, ticks: { color: pal.midnight, font: { size: 9 } } },
                x: { grid: { display: false }, ticks: { color: pal.midnight, font: { size: 9 } } }
              }
            }
          });
        }
      }
    }

    document.addEventListener("turbo:load", initCharts);
    document.addEventListener("DOMContentLoaded", initCharts);
    if (document.readyState === "complete" || document.readyState === "interactive") {
      setTimeout(initCharts, 100);
    }
  })();
</script>

<style>
.custom-scrollbar::-webkit-scrollbar { width: 4px; }
.custom-scrollbar::-webkit-scrollbar-track { background: rgba(0,0,0,0.05); }
.custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(0, 51, 255, 0.1); border-radius: 10px; }
</style>
