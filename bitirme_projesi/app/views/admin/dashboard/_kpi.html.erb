<%
  alert        = local_assigns.fetch(:alert, false)
  highlighted  = local_assigns.fetch(:highlighted, false)
  change       = local_assigns.fetch(:change, nil)
  positive     = local_assigns.fetch(:positive, true)

  border_cls = if alert
                 "border-brand-alert/40 shadow-lg shadow-brand-alert/5"
               elsif highlighted
                 "border-brand-azure/40 shadow-lg shadow-brand-azure/5"
               else
                 "border-brand-azure/10"
               end
%>
<div class="rounded-2xl bg-white border <%= border_cls %> p-5 shadow-2xl shadow-brand-midnight/5 transition-all hover:scale-[1.02] hover:bg-white group">
  <p class="text-[10px] uppercase font-black tracking-[0.2em] text-brand-midnight opacity-40 group-hover:opacity-100 transition-opacity"><%= title %></p>
  <div class="mt-2 flex items-baseline justify-between gap-3">
    <span class="text-3xl font-black tracking-tighter text-brand-midnight">
      <%= value %>
    </span>
    <% if change %>
      <span class="text-[10px] font-black px-2 py-1 rounded bg-brand-ice/40 <%= positive ? 'text-brand-azure' : 'text-brand-alert/60' %>">
        <%= change %>
      </span>
    <% end %>
  </div>
</div>
